            cand --list 'List available rollback artifacts'
            cand --dry-run 'Preview rollback restore or prune actions without modifying files or metadata'
            cand -y 'Accept confirmation prompts automatically'
            cand --yes 'Accept confirmation prompts automatically'
            cand --no-pager 'Prevent paging long command outputs'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;reinstall'= {
