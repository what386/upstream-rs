
use builtin;
use str;

set edit:completion:arg-completer[upstream] = {|@words|
    fn spaces {|n|
        builtin:repeat $n ' ' | str:join ''
    }
    fn cand {|text desc|
        edit:complex-candidate $text &display=$text' '(spaces (- 14 (wcswidth $text)))$desc
    }
    var command = 'upstream'
    for word $words[1..-1] {
        if (str:has-prefix $word '-') {
            break
        }
        set command = $command';'$word
    }
    var completions = [
        &'upstream'= {
            cand -y 'Accept confirmation prompts automatically'
            cand --yes 'Accept confirmation prompts automatically'
            cand --no-pager 'Prevent paging long command outputs'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
            cand -V 'Print version'
            cand --version 'Print version'
            cand install 'Install a release asset or direct download'
            cand build 'Build and install a package from source'
            cand remove 'Remove installed package files and metadata'
            cand uninstall 'Remove installed package files and metadata'
            cand rollback 'Restore or prune stored rollback artifacts'
            cand reinstall 'Reinstall packages from their stored source metadata'
            cand upgrade 'Check for or install package updates'
            cand list 'List installed packages'
            cand info 'Show details for one installed package'
            cand changelog 'Show release notes for an installed package'
            cand docs 'Search cached or fetched package README docs'
            cand probe 'Inspect releases, choose an asset, and install it'
            cand search 'Search provider repositories without installing'
            cand find 'Search repositories interactively and install one'
            cand config 'View and edit config.toml'
            cand auth 'View and edit auth.toml'
            cand package 'Manage installed package records and launcher entries'
            cand hooks 'Manage shell PATH hooks and local upstream data'
            cand import 'Import config, trust keys, packages, or a profile'
            cand export 'Export config, trust keys, packages, or a profile'
            cand doctor 'Run diagnostics to detect installation and integration issues'
            cand help 'Print this message or the help of the given subcommand(s)'
        }
        &'upstream;install'= {
            cand -t 'Release tag to install (defaults to latest matching the channel)'
            cand --tag 'Release tag to install (defaults to latest matching the channel)'
            cand -k 'Asset kind to install'
            cand --kind 'Asset kind to install'
            cand -p 'Source provider hosting the repository. Defaults to auto-detection'
            cand --provider 'Source provider hosting the repository. Defaults to auto-detection'
            cand --base-url 'Custom base URL. Defaults to provider''s root'
            cand -c 'Release channel to track for upgrades'
            cand --channel 'Release channel to track for upgrades'
            cand -m 'Match pattern to use as a hint for which asset to prefer'
            cand --match-pattern 'Match pattern to use as a hint for which asset to prefer'
            cand -e 'Exclude pattern to filter out unwanted assets (e.g., "rocm", "debug")'
            cand --exclude-pattern 'Exclude pattern to filter out unwanted assets (e.g., "rocm", "debug")'
            cand --trust 'Trust verification mode for downloaded assets'
            cand -d 'Create a desktop launcher entry for GUI applications'
            cand --desktop 'Create a desktop launcher entry for GUI applications'
            cand --dry-run 'Preview install resolution without downloading, installing, or writing metadata'
            cand -y 'Accept confirmation prompts automatically'
            cand --yes 'Accept confirmation prompts automatically'
            cand --no-pager 'Prevent paging long command outputs'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;build'= {
            cand -t 'Release tag to build (defaults to latest matching the channel)'
            cand --tag 'Release tag to build (defaults to latest matching the channel)'
            cand --branch 'Branch to build from instead of a release tag'
            cand -p 'Source provider hosting the repository. Defaults to auto-detection'
            cand --provider 'Source provider hosting the repository. Defaults to auto-detection'
            cand --base-url 'Custom base URL. Defaults to provider''s root'
            cand -c 'Release channel to track for future builds'
            cand --channel 'Release channel to track for future builds'
            cand --build-profile 'Build profile used to compile/install from source (auto-detected when omitted)'
            cand -d 'Create a desktop launcher entry for GUI applications'
            cand --desktop 'Create a desktop launcher entry for GUI applications'
            cand --dry-run 'Preview build resolution without compiling, installing, or writing metadata'
            cand -y 'Accept confirmation prompts automatically'
            cand --yes 'Accept confirmation prompts automatically'
            cand --no-pager 'Prevent paging long command outputs'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;remove'= {
            cand --purge 'Remove package-owned cached data as well as active files'
            cand --force 'Remove metadata even when uninstall cleanup fails'
            cand --dry-run 'Preview removal actions without deleting files or metadata'
            cand -y 'Accept confirmation prompts automatically'
            cand --yes 'Accept confirmation prompts automatically'
            cand --no-pager 'Prevent paging long command outputs'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;uninstall'= {
            cand --purge 'Remove package-owned cached data as well as active files'
