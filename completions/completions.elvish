            cand -y 'Accept confirmation prompts'
            cand --yes 'Accept confirmation prompts'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;find'= {
            cand -p 'Source provider to search (defaults to github)'
            cand --provider 'Source provider to search (defaults to github)'
            cand --base-url 'Custom base URL for self-hosted providers'
            cand --limit 'Maximum number of results to display'
            cand --language 'Restrict results to repositories with this primary language'
            cand --topic 'Restrict results to repositories tagged with this topic'
            cand --min-stars 'Restrict results to repositories with at least this many stars'
            cand --max-stars 'Restrict results to repositories with at most this many stars'
            cand --pushed-after 'Restrict results to repositories pushed on or after YYYY-MM-DD'
            cand --name 'Package name to register without prompting'
            cand -k 'File type to install'
            cand --kind 'File type to install'
            cand -c 'Update channel to track'
            cand --channel 'Update channel to track'
            cand -m 'Match pattern to use as a hint for which asset to prefer'
