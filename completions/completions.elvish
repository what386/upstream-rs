            cand --machine-readable 'Print one line per available update: "name oldver newver"'
            cand --json 'Print check results as JSON'
            cand --dry-run 'Preview upgrade resolution without downloading, installing, or writing metadata'
            cand -y 'Accept confirmation prompts automatically'
            cand --yes 'Accept confirmation prompts automatically'
