
use builtin;
use str;

set edit:completion:arg-completer[upstream] = {|@words|
    fn spaces {|n|
        builtin:repeat $n ' ' | str:join ''
    }
    fn cand {|text desc|
        edit:complex-candidate $text &display=$text' '(spaces (- 14 (wcswidth $text)))$desc
    }
    var command = 'upstream'
    for word $words[1..-1] {
        if (str:has-prefix $word '-') {
            break
        }
        set command = $command';'$word
    }
    var completions = [
        &'upstream'= {
            cand -y 'Accept confirmation prompts'
            cand --yes 'Accept confirmation prompts'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
            cand -V 'Print version'
            cand --version 'Print version'
            cand install 'Install a package from an upstream release source'
            cand build 'Build and install from source for release tags without artifacts'
            cand remove 'Remove one or more installed packages'
            cand rollback 'Manage stored rollback artifacts'
            cand reinstall 'Reinstall one or more packages (remove then install)'
            cand upgrade 'Upgrade installed packages to their latest versions'
            cand list 'List installed packages and their metadata'
            cand changelog 'Show upstream release notes for an installed package'
            cand docs 'Search package README documentation'
            cand probe 'Probe a repository/source, choose an asset, and install it'
            cand search 'Search provider repositories by keyword(s)'
            cand find 'Search repositories interactively and install a selected result'
            cand config 'Manage upstream configuration'
            cand package 'Manage package-specific behavior'
            cand hooks 'Manage shell integration hooks and local upstream data'
            cand import 'Import config, trusted keys, or exported packages'
            cand export 'Export config, trusted keys, or installed package references'
            cand doctor 'Run diagnostics to detect installation and integration issues'
            cand help 'Print this message or the help of the given subcommand(s)'
        }
        &'upstream;install'= {
            cand -t 'Version tag to install (defaults to latest)'
            cand --tag 'Version tag to install (defaults to latest)'
            cand -k 'File type to install'
            cand --kind 'File type to install'
            cand -p 'Source provider hosting the repository. Defaults to auto-detection'
            cand --provider 'Source provider hosting the repository. Defaults to auto-detection'
            cand --base-url 'Custom base URL. Defaults to provider''s root'
            cand -c 'Update channel to track'
            cand --channel 'Update channel to track'
            cand -m 'Match pattern to use as a hint for which asset to prefer'
            cand --match-pattern 'Match pattern to use as a hint for which asset to prefer'
            cand -e 'Exclude pattern to filter out unwanted assets (e.g., "rocm", "debug")'
            cand --exclude-pattern 'Exclude pattern to filter out unwanted assets (e.g., "rocm", "debug")'
            cand --trust 'Trust verification mode for downloaded assets'
            cand -d 'Whether or not to create a .desktop entry for GUI applications'
            cand --desktop 'Whether or not to create a .desktop entry for GUI applications'
            cand --dry-run 'Preview install resolution without downloading or writing files'
            cand -y 'Accept confirmation prompts'
            cand --yes 'Accept confirmation prompts'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;build'= {
            cand -t 'Version tag to build (defaults to latest)'
            cand --tag 'Version tag to build (defaults to latest)'
            cand --branch 'Branch name to build from (uses latest commit from that branch)'
            cand -p 'Source provider hosting the repository. Defaults to auto-detection'
            cand --provider 'Source provider hosting the repository. Defaults to auto-detection'
            cand --base-url 'Custom base URL. Defaults to provider''s root'
            cand -c 'Update channel to track'
            cand --channel 'Update channel to track'
            cand --build-profile 'Build profile used to compile/install from source (auto-detected when omitted)'
            cand -d 'Whether or not to create a .desktop entry for GUI applications'
            cand --desktop 'Whether or not to create a .desktop entry for GUI applications'
            cand --dry-run 'Preview build resolution without compiling or writing files'
            cand -y 'Accept confirmation prompts'
            cand --yes 'Accept confirmation prompts'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;remove'= {
            cand --purge 'Remove all associated cached data'
            cand --force 'Ignore uninstall errors and remove metadata anyway'
            cand --dry-run 'Preview removal actions without deleting files or metadata'
            cand -y 'Accept confirmation prompts'
            cand --yes 'Accept confirmation prompts'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;rollback'= {
            cand --prune 'Prune stored rollback artifacts for all packages or selected package names'
            cand --list 'List stored rollback artifacts'
            cand --dry-run 'Preview rollback restore or prune actions without modifying files or metadata'
            cand -y 'Accept confirmation prompts'
            cand --yes 'Accept confirmation prompts'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;reinstall'= {
            cand --trust 'Trust verification mode for release-asset reinstalls'
            cand --force 'Ignore uninstall errors and remove metadata anyway before reinstalling'
            cand --dry-run 'Preview reinstall resolution without removing, building, or writing files'
            cand -y 'Accept confirmation prompts'
            cand --yes 'Accept confirmation prompts'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;upgrade'= {
            cand --trust 'Trust verification mode for downloaded assets'
            cand --force 'Force upgrade even if already up to date'
            cand --check 'Check for available upgrades without applying them'
            cand --machine-readable 'Use script-friendly check output: one line per update, "name oldver newver"'
            cand --json 'Print check results as JSON'
            cand --dry-run 'Preview upgrade resolution without downloading or writing files'
            cand -y 'Accept confirmation prompts'
            cand --yes 'Accept confirmation prompts'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;list'= {
            cand --json 'Print raw package metadata as JSON'
            cand -y 'Accept confirmation prompts'
            cand --yes 'Accept confirmation prompts'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;changelog'= {
            cand --from 'Override the starting release tag'
            cand --to 'Override the ending release tag'
            cand -y 'Accept confirmation prompts'
            cand --yes 'Accept confirmation prompts'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;docs'= {
            cand --fetch 'Refresh cached README docs for named packages, or all packages when no names are provided'
            cand --offline 'Use only the cached README and skip network fetching'
            cand -y 'Accept confirmation prompts'
            cand --yes 'Accept confirmation prompts'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;probe'= {
            cand -p 'Source provider (defaults to github, or scraper for URLs)'
            cand --provider 'Source provider (defaults to github, or scraper for URLs)'
            cand --base-url 'Custom base URL for self-hosted providers'
            cand -c 'Channel view to display'
            cand --channel 'Channel view to display'
            cand --limit 'Number of releases to inspect instead of only the latest release'
            cand --tag 'Release tag to inspect (defaults to latest when --limit is omitted)'
            cand -k 'File type to show and install'
            cand --kind 'File type to show and install'
            cand --trust 'Trust verification mode for downloaded assets'
            cand --verbose 'Include scored candidate assets for each release'
            cand --include-incompatible 'Include assets that do not match the current OS/architecture or selected file type'
            cand --json 'Print dry-run probe results as JSON'
            cand -d 'Whether or not to create a .desktop entry for GUI applications'
            cand --desktop 'Whether or not to create a .desktop entry for GUI applications'
            cand --dry-run 'Show parsed releases without selecting, downloading, or installing'
            cand -y 'Accept confirmation prompts'
            cand --yes 'Accept confirmation prompts'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
        }
        &'upstream;search'= {
            cand -p 'Source provider to search (defaults to github)'
            cand --provider 'Source provider to search (defaults to github)'
            cand --base-url 'Custom base URL for self-hosted providers'
            cand --limit 'Maximum number of results to display'
            cand --language 'Restrict results to repositories with this primary language'
            cand --topic 'Restrict results to repositories tagged with this topic'
            cand --min-stars 'Restrict results to repositories with at least this many stars'
            cand --max-stars 'Restrict results to repositories with at most this many stars'
            cand --pushed-after 'Restrict results to repositories pushed on or after YYYY-MM-DD'
            cand --include-forks 'Include forked repositories in provider search results'
